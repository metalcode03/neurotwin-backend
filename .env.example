# Django Configuration
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (PostgreSQL)
DATABASE_URL=postgres://postgres:password@localhost:5432/neurotwin
DB_NAME=neurotwin
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Database Connection Pooling (Requirements: 31.4)
DB_POOL_SIZE=50
DB_POOL_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Redis Configuration
# Set USE_REDIS=True when Redis server is running
USE_REDIS=False
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_USE_SSL=False

# Redis Connection Pooling (Requirements: 31.5)
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_CONNECTION_POOL_MAX_CONNECTIONS=100

# Production Redis (AWS ElastiCache) - Uncomment for production
# REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
# REDIS_USE_SSL=True
# REDIS_PASSWORD=your_redis_password

# AI/ML Configuration
GOOGLE_API_KEY=your_google_api_key
CEREBRAS_API_KEY=your_cerebras_api_key
MISTRAL_API_KEY=your_mistral_api_key

# Meta Webhook Configuration
# Requirements: 10.2, 10.7 - Meta webhook signature verification
# Get META_APP_SECRET from Meta App Dashboard > Settings > Basic > App Secret
META_APP_SECRET=your_meta_app_secret_here
# Choose a secure random token for webhook verification
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
META_WEBHOOK_VERIFY_TOKEN=your_secure_random_token_here

# OAuth Configuration
OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/integrations/oauth/callback
FRONTEND_URL=http://localhost:3000

# Credential Encryption Keys
# Requirements: 17.1-17.4 - Separate encryption keys for different credential types
# Generate new keys with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Use different keys for each auth type in production!

# OAuth credentials encryption key
OAUTH_ENCRYPTION_KEY=generate_new_key_for_production

# Meta credentials encryption key
META_ENCRYPTION_KEY=generate_new_key_for_production

# API Key credentials encryption key
API_KEY_ENCRYPTION_KEY=generate_new_key_for_production

# Generic fallback encryption key (used if specific keys not set)
ENCRYPTION_KEY=generate_new_key_for_production

# Legacy key name (for backward compatibility)
TOKEN_ENCRYPTION_KEY=generate_new_key_for_production

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email Verification
EMAIL_VERIFICATION_TOKEN_LIFETIME_HOURS=24

# Rate Limiting
INSTALLATION_RATE_LIMIT=10
INSTALLATION_RATE_LIMIT_WINDOW=3600
API_RATE_LIMIT=1000

# Cache TTL (seconds)
CACHE_INTEGRATION_TYPES_TTL=300
CACHE_USER_INSTALLATIONS_TTL=60
CACHE_OAUTH_CONFIG_TTL=600

# Session Cleanup
INSTALLATION_SESSION_CLEANUP_HOURS=24

# Celery Configuration
# Requirements: 11.1-11.7 - Message queue system
# Celery uses Redis as broker (configured via REDIS_* variables above)
# Separate Redis DBs are used: DB 0 for cache, DB 1 for Celery broker, DB 2 for results

# Docker / Gunicorn Configuration
# Number of Gunicorn worker processes (recommended: 2 * CPU cores + 1)
GUNICORN_WORKERS=4
# Request timeout in seconds — workers are killed and restarted if a request exceeds this
GUNICORN_TIMEOUT=120
# Number of concurrent Celery worker processes
CELERY_CONCURRENCY=4

# Django-Q2 Configuration (legacy)
Q_WORKERS=4

# Payment Gateway Configuration
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_ENCRYPTION_KEY=your_flutterwave_encryption_key
# Webhook verification hash from Flutterwave Dashboard > Settings > Webhooks
FLUTTERWAVE_SECRET_HASH=your_flutterwave_webhook_secret_hash

# Optional: IP allowlist for webhook security (comma-separated)
# Get current IPs from Flutterwave documentation
# FLUTTERWAVE_ALLOWED_IPS=52.49.173.169,52.214.14.220,52.31.139.75
