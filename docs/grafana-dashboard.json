{
  "dashboard": {
    "title": "NeuroTwin Credit System Monitoring",
    "description": "Monitoring dashboard for credit operations, AI requests, and system health",
    "tags": ["neurotwin", "credits", "ai", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Credit Consumption Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(credit_deductions_total[5m])",
            "legendFormat": "{{user_tier}} - {{brain_mode}} - {{operation_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Credits/sec"},
          {"format": "short"}
        ],
        "alert": {
          "name": "High Credit Consumption",
          "conditions": [
            {
              "evaluator": {"params": [1000], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "message": "Credit consumption rate is unusually high",
          "noDataState": "no_data",
          "notifications": []
        }
      },
      {
        "id": 2,
        "title": "AI Request Rate",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(ai_requests_total[5m])",
            "legendFormat": "{{brain_mode}} - {{status}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Requests/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 3,
        "title": "AI Request Success Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(ai_requests_total{status=\"success\"}[5m]) / rate(ai_requests_total[5m]) * 100",
            "legendFormat": "Success Rate %",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "Success Rate", "max": 100, "min": 0},
          {"format": "short"}
        ],
        "alert": {
          "name": "Low AI Request Success Rate",
          "conditions": [
            {
              "evaluator": {"params": [95], "type": "lt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "message": "AI request failure rate exceeds 5% over 5 minute window",
          "noDataState": "no_data",
          "notifications": []
        }
      },
      {
        "id": 4,
        "title": "Credit Check Latency (p95)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(credit_check_latency_seconds_bucket[5m]))",
            "legendFormat": "p95 - {{cache_hit}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(credit_check_latency_seconds_bucket[5m]))",
            "legendFormat": "p50 - {{cache_hit}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Latency"},
          {"format": "short"}
        ],
        "alert": {
          "name": "High Credit Check Latency",
          "conditions": [
            {
              "evaluator": {"params": [0.1], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "message": "Credit check p95 latency exceeds 100ms",
          "noDataState": "no_data",
          "notifications": []
        }
      },
      {
        "id": 5,
        "title": "AI Request Latency Percentiles",
        "type": "graph",
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(ai_request_latency_seconds_bucket[5m]))",
            "legendFormat": "p95 - {{brain_mode}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(ai_request_latency_seconds_bucket[5m]))",
            "legendFormat": "p50 - {{brain_mode}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Latency"},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "Model Failures by Type",
        "type": "graph",
        "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(model_failures_total[5m])",
            "legendFormat": "{{model}} - {{error_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Failures/sec"},
          {"format": "short"}
        ],
        "alert": {
          "name": "High Provider Failure Rate",
          "conditions": [
            {
              "evaluator": {"params": [0.1], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "message": "Provider failure rate exceeds 10%",
          "noDataState": "no_data",
          "notifications": []
        }
      },
      {
        "id": 7,
        "title": "Total Tokens Consumed",
        "type": "graph",
        "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(ai_request_tokens_total[5m])",
            "legendFormat": "{{brain_mode}} - {{model_used}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Tokens/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 8,
        "title": "Model Selection Distribution",
        "type": "piechart",
        "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum by (selected_model) (rate(model_selections_total[5m]))",
            "legendFormat": "{{selected_model}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 9,
        "title": "Credit Operations by Tier",
        "type": "graph",
        "gridPos": {"x": 0, "y": 32, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(credit_deductions_total[5m])",
            "legendFormat": "{{user_tier}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Operations/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 10,
        "title": "Monthly Credit Resets",
        "type": "stat",
        "gridPos": {"x": 12, "y": 32, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(increase(credit_resets_total[24h]))",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        }
      }
    ]
  }
}
