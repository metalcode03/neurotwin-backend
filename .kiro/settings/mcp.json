{
  "mcpServers": {
    "web-search": {
      "command": "npx",
      "args": [
        "-y",
        "@brave/brave-search-mcp-server",
        "--transport",
        "stdio"
      ],
      "env": {
        "BRAVE_API_KEY": "BSAF6zNo-dwoNrvSk8N4oLriLapxa-s"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}",
        "GIT_USERNAME": "${GIT_USERNAME}"
      },
      "disabled": false,
      "autoApprove": [
        "git_status",
        "git_push",
        "git_read_file",
        "git_list_files"
      ],
      "disabledTools": [
        "create_branch",
        "create_pull_request",
        "create_issue",
        "create_or_update_file",
        "create_pull_request_review",
        "update_pull_request_branch",
        "merge_pull_request",
        "create_repository",
        "list_pull_requests"
      ]
    }
  }
}